{
  "name": "obsidian-wechatreading-highlights-sync",
  "version": "0.1.5",
  "description": "Sync WeChat Reading highlights, notes, shelf, and reading stats to Markdown. 同步微信读书书架、划线、想法和阅读统计.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "wechatreading",
    "wechat-reading",
    "highlights"
  ],
  "author": "EricZheng",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.11",
    "esbuild": "^0.25.12",
    "obsidian": "^1.6.7",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vitest": "^3.2.6"
  }
}
